# Supabase — required. Without these, /dashboard, /editor, and /t/[slug]
# will all 500 at request time. See db/migrations/*.sql for the schema to
# apply, then db/seed.sql for the kremmen-place demo tour.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (M3+)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stripe (M7+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_SOLO=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_BROKERAGE=

# Resend (M6+)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Upstash (M8+)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic (AI features — auto-name rooms, future auto-description)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
